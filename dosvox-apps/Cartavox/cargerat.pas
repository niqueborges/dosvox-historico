{-------------------------------------------------------------}
{       Retorna o tipo de acordo com a extençăo do arquivo
{-------------------------------------------------------------}

function geraTipoAplic (nome: string): string;
var ext: string;
    i: integer;
begin
    ext := '';
    if pos ('.', nome) <> 0 then
        for i := length (nome) downto 2 do
            if nome[i] = '.' then break
            else ext := upcase(nome[i]) + ext;

